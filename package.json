{
  "name": "minecraft-rcon",
  "version": "1.0.0",
  "description": "我的世界RCON远程控制前端页面",
  "license": "MIT",
  "author": "CherryLanterns",
  "type": "commonjs",
  "main": "server.js",
  "scripts": {
    "serve": "node server.js",
    "dev:backend": "npm run serve",
    "dev:frontend": "wait-on http://localhost:8080 && vite",
    "dev": "concurrently -k -n backend,frontend \"npm run dev:backend\" \"npm run dev:frontend\"",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "start": "node server.js"
  },
  "dependencies": {
    "express": "^4.18.2",
    "rcon-client": "^4.2.5"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^4.3.0",
    "autoprefixer": "^10.4.19",
    "concurrently": "^8.2.2",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.4",
    "typescript": "^5.6.0",
    "vite": "^5.4.2",
    "wait-on": "^7.0.1",
    "vue": "^3.4.4"
  }
}
